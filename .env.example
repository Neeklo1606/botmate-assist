# ─── Shared / Docker Compose ───────────────────────────────────────────────
JWT_SECRET=replace-with-at-least-32-random-characters
ENCRYPTION_MASTER_KEY=replace-with-at-least-32-random-characters

# ─── API (@botmate/api) — copy to apps/api/.env ───────────────────────────
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/botmate_assist?schema=public
# PORT=3001
# REDIS_URL=redis://localhost:6379
# ALLOWED_ORIGINS=http://localhost:8080,http://127.0.0.1:8080
# IP_RATE_LIMIT_PER_MIN=240
# TENANT_RATE_LIMIT_PER_MIN=120
# TENANT_REQUESTS_PER_MIN=60
# ENABLE_DEV_SEED=false
# DEV_SEED_EMAIL=dev@example.com
# DEV_SEED_PASSWORD=change-me-10chars
# DEV_SEED_NAME=Dev User
# ENABLE_DEMO_SEED=false
# DEMO_SEED_EMAIL=admin@example.com
# Production templates: apps/api/.env.production.example, apps/web/.env.production.example
# OPENAI_TEST_KEY=

# ─── Web (@botmate/web) — copy to apps/web/.env ───────────────────────────
# VITE_API_URL=http://localhost:3001
# VITE_SITE_URL=http://localhost:8080
