# Production API — copy to apps/api/.env (or inject via secret manager).
# See PRODUCTION_DEPLOYMENT_PACKAGE.md and OPERATIONAL_DEPLOYMENT_GUIDE.md.

NODE_ENV=production
PORT=3001

DATABASE_URL=postgresql://USER:PASSWORD@postgres-host:5432/botmate_assist?schema=public&sslmode=require
REDIS_URL=rediss://:PASSWORD@redis-host:6379

JWT_SECRET=replace-with-cryptographically-random-32plus-chars
ENCRYPTION_MASTER_KEY=replace-with-cryptographically-random-32plus-chars

# Comma-separated cabinet origins (HTTPS only in production).
ALLOWED_ORIGINS=https://app.example.com

# Rate limits (tune per plan / ingress)
IP_RATE_LIMIT_PER_MIN=240
TENANT_RATE_LIMIT_PER_MIN=120
TENANT_REQUESTS_PER_MIN=60

# ─── Production strict (recommended for first customers) ───────────────────
BOTMATE_PRODUCTION_STRICT=true
BOTMATE_WORKER_REJECT_STUB=true
BOTMATE_REALTIME_EVENT_FRAME=true
BOTMATE_REALTIME_BLOCK_TENANT_MISMATCH=true
BOTMATE_RUNTIME_TENANT_API=true
BOTMATE_MCP_REQUIRE_POLICY_CONTEXT=true

# ─── Runtime / governance (optional retention) ───────────────────────────────
# RUNTIME_EXECUTION_FACT_PURGE_ENABLED=true
# RUNTIME_GOVERNANCE_AUDIT_PURGE_ENABLED=true
# RUNTIME_STUCK_THRESHOLD_MS=1800000
# RUNTIME_RECONCILE_ENQUEUE_COOLDOWN_MS=60000

# Internal-only — do not enable for general tenants until runbook signed
# BOTMATE_ASSISTANT_RUN_ENQUEUE_ENABLED=true

# Emergency guardrails — prefer narrow tenant/subsystem toggles
# RUNTIME_DISABLED_TENANTS=
# RUNTIME_EMERGENCY_DISABLE=
# RUNTIME_DRAIN_MODE=hard

# Product analytics (Phase 12C) — tenant events + /health/product
BOTMATE_PRODUCT_ANALYTICS_ENABLED=true
# Fleet rollup on /health/product (internal ingress only)
# BOTMATE_PRODUCT_ANALYTICS_INTERNAL_HEALTH=true

# Never enable in production
ENABLE_DEV_SEED=false
ENABLE_DEMO_SEED=false

# Provider keys — per-tenant or platform (see CUSTOMER_SUCCESS_GUIDE.md)
# OPENAI_API_KEY=
