    "@botmate/shared": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/websocket": "^11.2.0",
    "@prisma/client": "^6.19.3",
    "dotenv": "^16.6.1",
    "fastify": "^5.8.5",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3"
  },
  "devDependencies": {
    "@botmate/config": "workspace:*",
