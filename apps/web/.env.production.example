# Production web build — set at `docker build` / CI (Vite embeds at build time).
# See PRODUCTION_DEPLOYMENT_PACKAGE.md and FRONTEND_PRODUCTION_MODE.md.

VITE_API_URL=https://api.example.com
VITE_SITE_URL=https://app.example.com

VITE_USE_REAL_AUTH=true
VITE_PRODUCTION_STRICT=true

VITE_PROJECTS_DATA_SOURCE=api
VITE_ASSISTANTS_DATA_SOURCE=api
VITE_CHAT_DATA_SOURCE=api
VITE_LEADS_DATA_SOURCE=api

VITE_REALTIME_ENABLED=true
VITE_RUNTIME_TENANT_UI=true
VITE_RUNTIME_WORKSPACE_UI=true

# Optional: explicit WS base when API host differs from inferred origin
# VITE_REALTIME_WS_URL=wss://api.example.com/api/v1/realtime/ws
