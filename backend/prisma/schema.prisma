generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  OPERATOR
}

enum SessionStatus {
  ACTIVE
  CLOSED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
  TOOL
}

enum Provider {
  OPENAI
}

model Tenant {
  id          String         @id @default(cuid())
  name        String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  users       User[]
  sessions    ChatSession[]
  tools       ToolInvocation[]
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String   @unique
  fullName     String
  passwordHash String
  role         Role     @default(OPERATOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions     ChatSession[] @relation("SessionUser")
  integrations IntegrationAccount[]
  apiKeys      ApiKey[]
}

model ChatSession {
  id            String        @id @default(cuid())
  tenantId       String
  userId         String?
  title          String?
  status         SessionStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User?         @relation("SessionUser", fields: [userId], references: [id], onDelete: SetNull)
  messages       Message[]

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
}

model Message {
  id            String      @id @default(cuid())
  tenantId       String
  sessionId      String
  role           MessageRole
  content        String
  metadata       Json?
  createdAt      DateTime   @default(now())
  session        ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@index([tenantId, createdAt])
}

model ToolInvocation {
  id            String   @id @default(cuid())
  tenantId       String
  sessionId      String?
  toolName       String
  input          Json
  output         Json?
  success        Boolean  @default(false)
  error          String?
  createdAt      DateTime @default(now())
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([toolName, createdAt])
}

model IntegrationAccount {
  id              String   @id @default(cuid())
  userId           String
  provider         Provider
  apiKeyEncrypted  String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, provider, isActive])
  @@unique([userId, provider])
}

model ApiKey {
  id              String    @id @default(cuid())
  tenantId        String
  userId          String
  name            String
  keyPrefix       String
  keyHash         String    @unique
  assistantId     String?
  allowedDomains  Json?
  rateLimitPerMin Int       @default(60)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  revokedAt       DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, isActive])
  @@index([keyPrefix])
}
